{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",

    "opener:default",
    "dialog:default",
    
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "$FS_ROOT/**" }]
    },

    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "run-python",
          "cmd": "/home/christophe/Workspace/coding-assistants/frugaast/.venv/bin/python",
          "args": ["/home/christophe/Workspace/coding-assistants/frugaast/server.py"]
        },
        {
          "name": "binaries/server",
          "sidecar": true
        }
      ]
    }
  ]
}
